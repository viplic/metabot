{
  "business": {
    "name": "Moj biznis",
    "language": "sr",
    "timezone": "Europe/Belgrade",
    "shortDescription": "Korisnicka podrska preko Messengera i Instagrama.",
    "defaultReply": "Hvala na poruci. Provericu dostupne informacije i, ako je potrebno, proslediti razgovor timu za podrsku.",
    "privacyNoticeUrl": "",
    "dataDeletionUrl": ""
  },
  "meta": {
    "graphApiVersion": "v25.0",
    "verifyToken": "change-this-token",
    "requireSignature": true,
    "appSecretEnv": "META_APP_SECRET",
    "pageAccessTokenEnv": "META_PAGE_ACCESS_TOKEN"
  },
  "channels": [
    {
      "id": "messenger-main",
      "type": "messenger",
      "name": "Facebook Messenger",
      "enabled": true,
      "pageId": "",
      "igAccountId": "",
      "sendEnabled": false,
      "pageAccessTokenEnv": "META_PAGE_ACCESS_TOKEN"
    },
    {
      "id": "instagram-main",
      "type": "instagram",
      "name": "Instagram Direct",
      "enabled": false,
      "pageId": "",
      "igAccountId": "",
      "sendEnabled": false,
      "pageAccessTokenEnv": "META_PAGE_ACCESS_TOKEN"
    }
  ],
  "automation": {
    "enabled": true,
    "policyWindowHours": 24,
    "humanAgentWindowDays": 7,
    "deduplicationWindowHours": 48,
    "confidenceThreshold": 0.72,
    "leadCapturePrompt": "Da bismo zavrsili zahtev, posaljite jos: {field}.",
    "handoffKeywords": ["agent", "operater", "covek", "čovek", "human", "uzivo"],
    "riskyKeywords": ["reklamacija", "advokat", "tužba", "tuzba", "povracaj novca", "refund", "kartica"],
    "collectFields": [
      {
        "id": "name",
        "label": "ime",
        "enabled": true,
        "required": false
      },
      {
        "id": "phone",
        "label": "telefon",
        "enabled": true,
        "required": false
      },
      {
        "id": "topic",
        "label": "tema upita",
        "enabled": true,
        "required": false
      }
    ],
    "rules": [
      {
        "id": "working-hours",
        "enabled": true,
        "name": "Radno vreme",
        "keywords": ["radno vreme", "otvoreno", "working hours"],
        "response": "Radimo ponedeljak-petak 09:00-17:00. Ako zelite, mogu odmah da prosledim razgovor timu za podrsku.",
        "confidence": 0.98
      },
      {
        "id": "location",
        "enabled": true,
        "name": "Lokacija",
        "keywords": ["lokacija", "adresa", "gde se nalazite"],
        "response": "Napisite tacnu adresu u podesavanjima automatizacije, pa ce se automatski slati klijentima.",
        "confidence": 0.95
      }
    ],
    "faqs": [
      {
        "id": "pricing",
        "enabled": true,
        "question": "Koliko kosta usluga?",
        "keywords": ["cena", "cenovnik", "koliko kosta", "price"],
        "answer": "Cene zavise od usluge. Posaljite sta vam treba i pripremicu odgovor ili cu proslediti timu za podrsku."
      },
      {
        "id": "appointment",
        "enabled": true,
        "question": "Kako da zakazem?",
        "keywords": ["zakazivanje", "termin", "rezervacija"],
        "answer": "Mozete poslati zeljeni datum, vreme i kontakt telefon. Agent ce potvrditi najblizi slobodan termin."
      }
    ]
  },
  "ai": {
    "enabled": true,
    "provider": "openai",
    "model": "gpt-5.5",
    "apiKeyEnv": "OPENAI_API_KEY",
    "maxInputChars": 2000,
    "maxOutputTokens": 500,
    "maxContextChars": 4000,
    "maxHistoryChars": 1600,
    "maxImages": 3,
    "maxImageBytes": 5242880,
    "temperature": 0.2,
    "modelRouting": {
      "enabled": true,
      "simpleModel": "gpt-5.4-nano",
      "standardModel": "gpt-5.4-mini",
      "complexModel": "gpt-5.5",
      "visionModel": "gpt-5.5",
      "standardMinChars": 220,
      "complexMinChars": 900,
      "complexKeywords": ["analiziraj", "strategija", "uporedi", "objasni detaljno", "detaljno", "plan", "problem", "greska", "greška", "kod", "integracija", "ugovor", "reklamacija", "pravni", "izracunaj", "izračunaj"]
    },
    "fallbackToHumanOnError": true,
    "systemPrompt": "Ti si iskusan predstavnik korisnicke podrske za konkretan shop. Odgovaraj kratko, tacno, prirodno i bez izmisljanja. Ne pominji da si AI ili automatizacija. Ako nisi siguran, predlozi da tim proveri zahtev."
  },
  "catalog": {
    "sourceUrl": "",
    "autoRefreshEnabled": true,
    "refreshEveryHours": 24,
    "lastRefreshAt": "",
    "maxPages": 8
  },
  "orders": {
    "enabled": true,
    "requiredFields": ["name", "phone", "street", "city", "postalCode", "product"],
    "optionalFields": ["color", "model", "quantity", "note"],
    "captureComplaints": true
  },
  "usage": {
    "monthlyLimitUsd": 20,
    "warnAtPercent": 80
  },
  "integrations": {
    "googleSheets": {
      "enabled": false,
      "webhookUrlEnv": "",
      "sheetUrl": ""
    }
  },
  "knowledge": {
    "enabled": true,
    "minScore": 0.35,
    "autoReplyThreshold": 0.82,
    "maxMatches": 4,
    "documents": [
      {
        "id": "privacy-basics",
        "enabled": true,
        "title": "Privatnost i brisanje podataka",
        "keywords": ["privatnost", "brisanje", "podaci", "gdpr"],
        "content": "Korisnik moze zatraziti brisanje podataka. Sistem cuva samo podatke potrebne za podrsku i postuje retention podesavanje.",
        "response": "Mozete zatraziti brisanje podataka. Cuvamo samo podatke potrebne za podrsku i postujemo podeseni rok cuvanja."
      }
    ]
  },
  "handoff": {
    "enabled": true,
    "mode": "conversation_routing",
    "message": "Razumem. Prosledicu razgovor timu za podrsku.",
    "ticketing": {
      "enabled": false,
      "provider": "webhook",
      "webhookUrlEnv": "TICKETING_WEBHOOK_URL"
    }
  },
  "privacy": {
    "retentionDays": 30,
    "redactLogs": true,
    "storeRawEvents": false
  }
}
